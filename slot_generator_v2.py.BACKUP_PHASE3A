def norm(s: str) -> str:
    return re.sub(r"\s+", " ", (s or "").strip()).lower()

def safe_str(v) -> str:
    return "" if v is None else str(v).strip()

def norm_medical(s: str) -> str:
    t = (s or "").lower()
    t = t.replace("’", "'")
    t = re.sub(r"[/\\|,_;:()\[\]{}\-]+", " ", t)
    t = re.sub(r"[^a-z0-9\s]+", " ", t)
    t = re.sub(r"\s+", " ", t).strip()
    t = t.replace("o a", "oa")
    return t

