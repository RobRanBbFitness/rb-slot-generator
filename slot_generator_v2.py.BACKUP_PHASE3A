def _is_overloaded_error(exc: Exception) -> bool:
    name = exc.__class__.__name__.lower()
    if "overloaded" in name:
        return True
    msg = str(exc).lower()
    return ("overloaded" in msg) or ("error code: 529" in msg) or (" 529 " in msg) or ("status code: 529" in msg)

def _looks_like_transient_error(exc: Exception) -> bool:
    if _is_overloaded_error(exc):
        return True

    name = exc.__class__.__name__.lower()
    msg = str(exc).lower()

    transient_class_hints = [
        "ratelimit", "rate_limit",
        "timeout", "timedout",
        "apiconnection", "connection",
        "serviceunavailable", "unavailable",
        "internalserver", "servererror", "apierror",
        "temporarily", "retry",
    ]
    if any(h in name for h in transient_class_hints):
        return True

    transient_msg_hints = [
        "timed out", "timeout",
        "connection reset", "connection aborted", "connection error",
        "temporarily unavailable", "try again",
        "gateway timeout", "bad gateway", "service unavailable",
        "status code: 500", "status code: 502", "status code: 503", "status code: 504",
        "error code: 500", "error code: 502", "error code: 503", "error code: 504",
        " 500 ", " 502 ", " 503 ", " 504 ",
    ]
    if any(h in msg for h in transient_msg_hints):
        return True

    return False

